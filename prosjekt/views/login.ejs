<!-- Definerer dokumenttype -->
<!DOCTYPE html>
<!-- Starter HTML og setter språk -->
<html lang="no">
<!-- Head-delen med metadata og stilark -->
<head>
<!-- UTF-8 tegnsett for norske tegn -->
<meta charset="UTF-8" />
<!-- Responsiv visning på mobil -->
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<!-- Sidetittel -->
<title>Logg inn</title>

 <!-- Faviconer: legg filene i /public -->
  <link rel="icon" href="/prosjekt/Public/flowerFavicon.ico" type="image/x-icon" /> <!-- Klassisk .ico-favicon -->
  <link rel="icon" type="image/png" sizes="32x32" href="/prosjekt/Public/flowerFavicon32-32.png" /> <!-- 32x32 PNG -->
  <link rel="icon" type="image/png" sizes="16x16" href="/prosjekt/Public/flowerFavicon16-16.png" /> <!-- 16x16 PNG -->
  <link rel="icon" type="image/svg+xml" href="/prosjekt/Public/flowerFavicon.svg" /> <!-- SVG (valgfritt) -->
  <link rel="apple-touch-icon" sizes="180x180" href="/prosjekt/Public/flowerFavicon1.png" /> <!-- iOS-ikon -->
  <meta name="theme-color" content="#DDE5B6" /> <!-- Valgfri tema-farge for mobilnettlesere -->

<!-- Knytter til CSS -->
<link rel="stylesheet" href="/styles.css" />
</head>
<!-- Kroppen av dokumentet -->
<body>
<!-- Hovedoverskrift -->
<h1>Logg inn</h1>
 
    <!-- Viser feilmelding hvis den finnes -->
<% if (error) { %>
<!-- Avsnitt for feilmelding -->
<p class="message error"><%= error %></p>
<% } %>
 
    <!-- Viser suksessmelding hvis den finnes -->
<% if (success) { %>
<!-- Avsnitt for suksessmelding -->
<p class="message success"><%= success %></p>
<% } %>
 
    <!-- Login-skjema som sender til /login via POST -->


<form action="/login" method="POST" class="card">
<!-- Etikett for e-post -->
<label for="email">E-post</label>
<!-- Input-felt for e-post -->
<input id="email" name="email" type="email" required placeholder="din@epost.no" />
 
      <!-- Etikett for passord -->
<label for="password">Passord</label>
<!-- Input-felt for passord -->
<input id="password" name="password" type="password" required placeholder="Ditt passord" />
 
      <!-- Sendeknapp -->
<button type="submit">Logg inn</button>
</form>

    <!-- Lenke til registreringssiden -->
<p>
      Har du ikke en konto?
<!-- Lenke til registrering -->
<a href="/register">Registrer deg her</a>
</p>


</body>
</html>