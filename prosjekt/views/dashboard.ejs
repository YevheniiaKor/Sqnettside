    <div class="overlay"> <!-- Overlay som vises ved hover -->
      <div class="text">Ghost of Tsushima unfolds in the Kamakura era, with the Mongol Empire ivanding Tsushima, and depicts the main protagonist Jin Sakai taking unrelenting revenge against the Mongolian armed forces.</div> <!-- Tekst i overlay -->
      <div class="text2">Game rating: 18+</div>
      <div class="text3">65GB Minimum</div>
        <div class="text4">1 player</div>
    </div> <!-- Slutt overlay -->
  </div> <!-- Slutt container -->

